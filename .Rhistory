nt_auqa_val <- raw_t11 |>
slice(30) |>
select(-1, -2, -3) |>
mutate(across(everything(), as.character)) |>
pivot_longer(everything(),
names_to  = "year",
values_to = "aqua_val") |>
mutate(aqua_val = as.numeric(aqua_val)) |>
filter(!is.na(aqua_val)) |>
mutate(state = "NT")
#quantity
nt_wild_vol <- raw_t11 |>
slice(56) |>
select(-1, -2, -3) |>
mutate(across(everything(), as.character)) |>
pivot_longer(everything(),
